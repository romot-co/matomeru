# Test files
**/__tests__/**
**/*.test.ts

# Development files
.vscode/**
.vscode-test/**
.claude/**
.github/**
src/**
.gitignore
.yarnrc
vsc-extension-quickstart.md
**/tsconfig.json
**/.eslintrc.json
**/*.map
**/*.ts
coverage/**
jest.config.js
jest.integration.config.js
jest.integration.real.config.js
.eslintrc.js
RELEASE.md

# Source files
src/**/*.ts
!src/**/*.d.ts

# Make sure grammars are included
!out/grammars/**

# Node modules
node_modules/**
!node_modules/minimatch/**
!node_modules/brace-expansion/**
!node_modules/balanced-match/**
!node_modules/isbinaryfile/**
!node_modules/web-tree-sitter/**
!node_modules/tree-sitter-wasm-prebuilt/**
!node_modules/js-yaml/**
!node_modules/@vscode/l10n/**

# Other development files
.eslintrc.json
webpack.config.js
*.vsix

# Trim development-only artifacts from bundled runtime dependencies
node_modules/**/.github/**
node_modules/**/*.d.ts
node_modules/**/*.map
